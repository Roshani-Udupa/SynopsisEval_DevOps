# ── Synopsis Review Portal — Backend Environment ──────────────────────────
# Copy this to .env and fill in your values

# PostgreSQL connection string
# Use localhost when running FastAPI on your machine.
# Use db when running FastAPI inside the same Docker Compose network.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/synopsis_portal

# JWT secret — change this in production!
SECRET_KEY=REPLACE_WITH_A_STRONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_BYTES=10485760

# Dev settings
DEBUG=true

# Frontend origin(s) for CORS (comma-separated in production)
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# SMTP email delivery
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
EMAIL_FROM_NAME=Synopsis Review Portal
EMAIL_FROM_ADDRESS=your-smtp-username
FRONTEND_URL=http://localhost:5173
